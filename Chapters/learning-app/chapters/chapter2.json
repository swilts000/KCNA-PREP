        {
            "title": "Lesson 3: CNCF Project Maturity & Governance",
            "navTitle": "CNCF Projects & Governance",
            "cards": [
                {
                    "title": "Project Maturity Levels",
                    "content": [
                        { "type": "text", "value": "CNCF categorizes projects into three maturity levels:" },
                        { "type": "grid", "columns": 3, "items": [
                            { "icon": "🧪", "title": "Sandbox", "text": "Early-stage, experimental projects" },
                            { "icon": "🌱", "title": "Incubating", "text": "Used in production, active contributions" },
                            { "icon": "🎓", "title": "Graduated", "text": "Multi-org contributors, security audited" }
                        ]},
                        { "type": "keypoint", "badge": "All CNCF Projects Must", "value": "Follow the CNCF Code of Conduct and CNCF IP Policy (usually Apache 2.0 + CC BY 4.0)" }
                    ]
                },
                {
                    "title": "Example CNCF Projects by Level",
                    "content": [
                        { "type": "nested", "title": "Graduated Projects", "content": [
                            { "type": "tags", "items": [
                                { "text": "Kubernetes", "primary": true },
                                { "text": "Prometheus", "primary": true },
                                { "text": "Envoy", "primary": true },
                                { "text": "containerd", "primary": true },
                                { "text": "Helm", "primary": true },
                                { "text": "Fluentd", "primary": true }
                            ]}
                        ]},
                        { "type": "nested", "title": "Incubating Projects", "content": [
                            { "type": "tags", "items": ["Argo", "Cilium", "Dapr", "Knative", "KEDA"] }
                        ]}
                    ]
                },
                {
                    "title": "CNCF Governance Structure",
                    "content": [
                        { "type": "concept", "title": "Minimal Viable Governance", "value": "Projects self-govern unless intervention is needed. CNCF provides structure without micromanagement." },
                        { "type": "text", "value": "<strong>CNCF Governing Bodies:</strong>" },
                        { "type": "grid", "columns": 3, "items": [
                            { "icon": "🏛️", "title": "Governing Board (GB)", "text": "Business, budget, marketing" },
                            { "icon": "🔧", "title": "TOC", "text": "Technical vision, project approval, maturity decisions" },
                            { "icon": "👥", "title": "End User Community", "text": "Feedback from real users" }
                        ]},
                        { "type": "example", "title": "First Graduated Project", "value": "Kubernetes was the first project to graduate in 2018." }
