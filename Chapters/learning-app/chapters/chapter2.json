            "title": "Lesson 1: OSS and Open Standards",
            "navTitle": "OSS & Open Standards",
            "cards": [
                {
                    "title": "What is Open Source Software (OSS)?",
                    "content": [
                        { "type": "highlight", "value": "Software whose source code is publicly available for anyone to study, modify, and distribute" },
                        { "type": "quote", "value": "OSS is when the source code of the software is publicly accessible and anyone can study, modify, and distribute it for any purpose." },
                        { "type": "nested", "title": "Key Characteristics", "content": [
                            { "type": "list", "items": [
                                "Requires an <strong>open source license</strong> (Apache 2.0, GPLv3, MIT, etc.)",
                                "Can be used <strong>commercially</strong> without licensing fees",
                                "Encourages <strong>community collaboration</strong>",
                                "Promotes <strong>transparency</strong> and <strong>innovation</strong>"
                            ]}
                        ]},
                        { "type": "nested", "title": "Major OSS Projects", "content": [
                            { "type": "tags", "items": ["Linux", "Kubernetes", "Terraform", "Prometheus", "Django", "PostgreSQL", "Node.js", "React"] }
                        ]}
                    ]
                },
                {
                    "title": "Open Container Initiative (OCI)",
                    "content": [
                        { "type": "text", "value": "Founded in <strong>2015</strong> to standardize container formats and runtimes." },
                        { "type": "keypoint", "badge": "Analogy", "value": "Standardized wheel sizes allow any wheel to fit any car; OCI standards allow any compliant container runtime or image to work together." },
                        { "type": "text", "value": "<strong>OCI Specifications:</strong>" },
                        { "type": "grid", "columns": 3, "items": [
                            { "icon": "📦", "title": "Image Spec", "text": "How container images are built and packaged" },
                            { "icon": "⚙️", "title": "Runtime Spec", "text": "How containers execute and behave" },
                            { "icon": "🔄", "title": "Distribution Spec", "text": "How images are transferred via registries" }
                        ]},
                        { "type": "concept", "title": "Why Open Standards Matter", "value": "✅ Avoid vendor lock-in ✅ Ensure compatibility ✅ Enable ecosystem growth ✅ Promote interoperability" }
                    ]
                }
            ],
            "lab": {
                "title": "OSS & OCI Quiz",
                "type": "quiz",
                "questions": [
                    {
                        "question": "What does OSS stand for?",
                        "options": ["Online Software Service", "Open Source Software", "Operating System Software"],
                        "answer": "1"
                    },
                    {
                        "question": "When was the Open Container Initiative (OCI) founded?",
                        "options": ["2010", "2015", "2018"],
                        "answer": "1"
                    },
                    {
                        "question": "Which are OCI specifications? (Select all that apply)",
                        "options": [
                            { "text": "Image Specification", "value": "image" },
