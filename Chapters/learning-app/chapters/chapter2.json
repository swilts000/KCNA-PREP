                            { "text": "Distribution Specification", "value": "distribution" },
                            { "text": "Network Specification", "value": "network" }
                        ],
                        "answer": ["image", "runtime", "distribution"],
                        "multi": true
                    },
                    {
                        "question": "What is a key benefit of open standards?",
                        "options": ["Increased vendor lock-in", "Avoid vendor lock-in", "Higher licensing costs"],
                        "answer": "1"
                    }
                ]
            }
        },
