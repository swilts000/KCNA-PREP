                    { "text": "Deploy", "zone": "pipeline", "order": 5 }
                ]
            }
        },
        {
            "title": "Lesson 3: GitOps",
            "navTitle": "GitOps",
            "cards": [
                {
                    "title": "What is GitOps?",
                    "content": [
                        { "type": "highlight", "value": "GitOps = CI/CD + Infrastructure as Code + Git as single source of truth" },
                        { "type": "concept", "title": "GitOps", "value": "Extends CI/CD by using Git as the single source of truth for infrastructure and application configuration." },
                        { "type": "keypoint", "badge": "Core", "value": "Git eliminates manual changes by enforcing declarative configuration stored in version control." }
                    ]
                },
                {
                    "title": "GitOps Core Elements",
                    "content": [
                        { "type": "nested", "title": "Three Core Elements", "content": [
                            { "type": "list", "items": [
                                "<strong>Merge Requests (MRs)</strong> - Code review, collaboration, audit trail",
                                "<strong>Infrastructure as Code (IaC)</strong> - Declarative configuration stored in Git",
                                "<strong>CI/CD Automation</strong> - Ensures environments match Git definitions"
                            ]}
                        ]}
                    ]
                },
                {
                    "title": "Infrastructure Drift",
                    "content": [
                        { "type": "concept", "title": "Infrastructure Drift", "value": "Occurs when the live environment differs from the desired state defined in IaC." },
                        { "type": "keypoint", "badge": "Solution", "value": "GitOps eliminates drift by automatically overwriting manual changes to match Git definitions." },
                        { "type": "example", "title": "Example", "value": "If someone manually deletes a Kubernetes Deployment, GitOps tools detect drift and automatically recreate missing resources based on Git definitions." }
                    ]
                },
                {
                    "title": "GitOps Tools",
                    "content": [
                        { "type": "text", "value": "<strong>Popular GitOps tools:</strong>" },
                        { "type": "tags", "items": [
                            { "text": "ArgoCD", "primary": true },
                            { "text": "FluxCD", "primary": true },
                            { "text": "Jenkins X", "primary": true }
                        ]},
                        { "type": "keypoint", "badge": "Function", "value": "These tools continuously sync Git changes to Kubernetes clusters." }
                    ]
                }
            ],
            "lab": {
                "title": "GitOps Elements",
                "type": "dragdrop",
                "instructions": "Categorize each item to the correct GitOps element:",
                "zones": [
                    { "id": "elements", "title": "GitOps Core Elements" },
                    { "id": "tools", "title": "GitOps Tools" },
                    { "id": "practices", "title": "GitOps Practices" }
                ],
                "items": [
                    { "text": "Merge Requests (MRs)", "zone": "elements" },
                    { "text": "Infrastructure as Code (IaC)", "zone": "elements" },
                    { "text": "CI/CD Automation", "zone": "elements" },
