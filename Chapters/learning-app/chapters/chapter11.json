    "lessons": [
        {
            "title": "Lesson 1: Cloud Native Application Delivery",
            "navTitle": "Cloud Native Delivery",
            "cards": [
                {
                    "title": "What is a Release?",
                    "content": [
                        { "type": "concept", "title": "Release", "value": "A version of software containing new features, fixes, or enhancements. Releases use semantic versioning (e.g., v1.0.0)." },
                        { "type": "text", "value": "<strong>Automation enables:</strong>" },
                        { "type": "grid", "columns": 2, "items": [
                            { "icon": "⚡", "text": "Faster delivery" },
                            { "icon": "🛡️", "text": "More stable releases" },
                            { "icon": "📈", "text": "Higher productivity" },
                            { "icon": "🐛", "text": "Fewer bugs through automated testing" },
                            { "icon": "🔄", "text": "Repeatable, predictable results" },
                            { "icon": "⏪", "text": "Quick rollback capability" }
                        ]}
                    ]
                },
                {
                    "title": "Continuous Lifecycle",
                    "content": [
                        { "type": "highlight", "value": "Application delivery follows a continuous lifecycle" },
                        { "type": "tags", "items": ["CODE", "BUILD", "TEST", "RELEASE", "DEPLOY", "OPERATE", "MONITOR", "PLAN"] },
                        { "type": "keypoint", "badge": "Benefit", "value": "Automation allows teams to ship updates multiple times per day and roll back quickly when needed." }
                    ]
                },
                {
                    "title": "Why Automation Matters",
                    "content": [
                        { "type": "text", "value": "Cloud Native applications often consist of many microservices. Delivering them manually is slow and error-prone." },
                        { "type": "list", "items": [
                            "❌ Manual delivery is slow and error-prone",
                            "❌ Cannot scale to dozens of microservices",
                            "❌ Human mistakes cause outages",
                            "✅ Automation ensures consistency",
                            "✅ Enables frequent, safe releases",
                            "✅ Reduces risk through small increments"
                        ]}
                    ]
                }
            ],
            "lab": {
                "title": "Application Delivery Quiz",
                "type": "quiz",
                "questions": [
                    {
                        "question": "What is a release?",
                        "options": ["A version of software delivered to users", "A build artifact", "A deployment pipeline", "A testing phase"],
                        "answer": "0"
                    },
                    {
                        "question": "What does automation enable?",
                        "options": ["Slower delivery", "More stable releases", "More bugs", "Manual processes"],
                        "answer": "1"
                    },
                    {
                        "question": "Which is NOT part of the continuous lifecycle?",
                        "options": ["Build", "Test", "Monitor", "Delete"],
                        "answer": "3"
                    }
                ]
            }
        },
        {
            "title": "Lesson 2: CI/CD Fundamentals",
            "navTitle": "CI/CD",
            "cards": [
                {
                    "title": "Continuous Integration (CI)",
                    "content": [
                        { "type": "concept", "title": "CI", "value": "Automates building and testing code whenever developers commit changes. It ensures the software is always in a working state." },
                        { "type": "grid", "columns": 2, "items": [
                            { "icon": "🔨", "title": "Build", "text": "Compile code and create artifacts" },
                            { "icon": "🧪", "title": "Test", "text": "Run automated tests to verify quality" }
                        ]},
                        { "type": "keypoint", "badge": "Goal", "value": "CI catches issues early by running tests on every commit." }
                    ]
                },
                {
                    "title": "Continuous Delivery (CD) vs Continuous Deployment",
                    "content": [
                        { "type": "comparison", "leftTitle": "Continuous Delivery", "rightTitle": "Continuous Deployment",
                            "left": ["Packages tested code into artifacts", "Stores in registries", "Deployment requires human approval", "Safer for production"],
                            "right": ["Fully automates deployment", "No human intervention needed", "Deploys once tests pass", "Faster but requires confidence"]
                        }
                    ]
                },
                {
                    "title": "CI/CD Pipeline",
                    "content": [
                        { "type": "text", "value": "A pipeline is a sequence of automated jobs:" },
                        { "type": "tags", "items": ["Build", "Test", "Analyze", "Package", "Deploy"] },
                        { "type": "keypoint", "badge": "Strategy", "value": "Small, frequent releases reduce risk and improve stability." }
                    ]
                },
                {
                    "title": "Popular CI/CD Tools",
                    "content": [
                        { "type": "text", "value": "<strong>Industry-standard CI/CD tools:</strong>" },
                        { "type": "tags", "items": [
                            { "text": "ArgoCD", "primary": true },
                            { "text": "Jenkins", "primary": true },
                            { "text": "GitLab CI", "primary": true },
                            { "text": "Tekton" },
                            { "text": "GitHub Actions" },
                            { "text": "Spinnaker" },
                            { "text": "FluxCD" },
                            { "text": "GoCD" },
                            { "text": "CircleCI" },
                            { "text": "TravisCI" }
                        ]}
                    ]
                }
            ],
            "lab": {
