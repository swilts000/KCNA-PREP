                    },
                    {
                        "question": "Which autoscaler adjusts pod replicas?",
                        "options": ["VPA", "HPA", "Cluster Autoscaler", "Node Autoscaler"],
                        "answer": "1"
                    },
                    {
                        "question": "What should you set for all production workloads? (Select all that apply)",
                        "options": [
                            { "text": "Resource requests", "value": "requests" },
                            { "text": "Resource limits", "value": "limits" },
                            { "text": "Health checks (probes)", "value": "probes" },
                            { "text": "Root access", "value": "root" }
